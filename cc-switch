#!/usr/bin/env bash
# cc-switch - Dead simple Claude Code auth switcher
# Shares all config between accounts. Only credentials are separate.
# https://github.com/matthew-plusprogramming/cc-auth-switcher

set -euo pipefail

CLAUDE_HOME="${HOME}/.claude"
SHELL_RC="${HOME}/.zshrc"
[[ -f "${HOME}/.bashrc" && ! -f "${HOME}/.zshrc" ]] && SHELL_RC="${HOME}/.bashrc"

RED='\033[0;31m'
GREEN='\033[0;32m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

usage() {
  cat <<EOF
cc-switch - Claude Code auth switcher

Usage: cc-switch <command>

Commands:
  add <name>      Create a new account profile and shell alias
  remove <name>   Remove an account profile and its alias
  swap <name>     Swap ~/.claude auth to a profile (use plain 'claude')
  list            Show configured accounts
  sync            Re-sync symlinks (run after Claude adds new config files)
  warm            Refresh tokens for inactive profiles
  warm-setup      Install launchd job to warm every 30 minutes
  warm-uninstall  Remove the warming launchd job
  uninstall       Remove all profiles and aliases

Examples:
  cc-switch add work        # creates 'work' alias and ~/.claude-work
  cc-switch add personal    # creates 'personal' alias and ~/.claude-personal
  cc-switch remove personal # removes it

Use named aliases (each profile has its own config dir):
  work                      # Claude Code with work account
  personal                  # Claude Code with personal account

Or swap in-place (simplest — just swaps auth in ~/.claude):
  cc-switch swap work       # now plain 'claude' uses work credentials
EOF
}

check_claude() {
  if [[ ! -d "$CLAUDE_HOME" ]]; then
    echo -e "${RED}Error:${RESET} ~/.claude not found. Run Claude Code at least once first."
    exit 1
  fi
}

validate_name() {
  local name="$1"
  if [[ -z "$name" ]]; then
    echo -e "${RED}Error:${RESET} Profile name required."
    echo "Usage: cc-switch add <name>"
    exit 1
  fi
  if [[ "$name" =~ [^a-zA-Z0-9_-] ]]; then
    echo -e "${RED}Error:${RESET} Profile name can only contain letters, numbers, hyphens, and underscores."
    exit 1
  fi
}

# Symlink everything from ~/.claude into a profile dir, except credentials
link_profile() {
  local profile_dir="$1"
  mkdir -p "$profile_dir"

  # Symlink visible files/dirs
  for item in "$CLAUDE_HOME"/*; do
    [[ ! -e "$item" ]] && continue
    local name
    name=$(basename "$item")
    if [[ -L "$profile_dir/$name" && "$(readlink "$profile_dir/$name")" == "$item" ]]; then
      continue
    fi
    [[ -e "$profile_dir/$name" || -L "$profile_dir/$name" ]] && rm -rf "$profile_dir/$name"
    ln -s "$item" "$profile_dir/$name"
  done

  # Symlink hidden files/dirs (except .credentials.json)
  for item in "$CLAUDE_HOME"/.*; do
    [[ ! -e "$item" ]] && continue
    local name
    name=$(basename "$item")
    [[ "$name" == "." || "$name" == ".." ]] && continue
    [[ "$name" == ".credentials.json" ]] && continue
    if [[ -L "$profile_dir/$name" && "$(readlink "$profile_dir/$name")" == "$item" ]]; then
      continue
    fi
    [[ -e "$profile_dir/$name" || -L "$profile_dir/$name" ]] && rm -rf "$profile_dir/$name"
    ln -s "$item" "$profile_dir/$name"
  done

  # Remove credentials symlink if it exists (each profile owns its own)
  if [[ -L "$profile_dir/.credentials.json" ]]; then
    rm "$profile_dir/.credentials.json"
  fi
}

# Get all profile names from shell rc
get_profiles() {
  grep "# cc-switch:" "$SHELL_RC" 2>/dev/null | sed 's/.*# cc-switch: //' || true
}

cmd_add() {
  local name="${1:-}"
  validate_name "$name"
  check_claude

  local profile_dir="$HOME/.claude-$name"

  # Check if already exists
  if grep -q "# cc-switch: $name" "$SHELL_RC" 2>/dev/null; then
    echo -e "${DIM}Profile '$name' already exists.${RESET}"
    return
  fi

  link_profile "$profile_dir"

  # Add alias to shell rc
  echo "alias $name='CLAUDE_CONFIG_DIR=~/.claude-$name claude' # cc-switch: $name" >> "$SHELL_RC"

  echo -e "${GREEN}+${RESET} Created profile ${BOLD}$name${RESET}"
  echo -e "  ${DIM}Config: ~/.claude-$name${RESET}"
  echo ""
  echo -e "Run: ${BOLD}source $SHELL_RC${RESET} then ${BOLD}$name${RESET} to log in"
}

cmd_remove() {
  local name="${1:-}"
  validate_name "$name"

  local profile_dir="$HOME/.claude-$name"

  if [[ -d "$profile_dir" ]]; then
    rm -rf "$profile_dir"
    echo -e "${RED}-${RESET} Removed ~/.claude-$name"
  fi

  if [[ -f "$SHELL_RC" ]]; then
    sed -i '' "/# cc-switch: $name$/d" "$SHELL_RC"
    echo -e "${RED}-${RESET} Removed alias from $(basename "$SHELL_RC")"
  fi

  echo ""
  echo -e "${GREEN}Done.${RESET} Run: source $SHELL_RC"
}

cmd_swap() {
  local from_profile="" force=false name=""

  # Parse flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --from)  from_profile="$2"; shift 2 ;;
      --force) force=true; shift ;;
      *)       name="$1"; shift ;;
    esac
  done

  validate_name "$name"
  check_claude

  local profile_creds="$HOME/.claude-$name/.credentials.json"
  local swap_marker="$CLAUDE_HOME/.cc-swap-active"

  if [[ ! -f "$profile_creds" ]]; then
    echo -e "${RED}Error:${RESET} Profile '$name' has no credentials. Log in first by running: $name"
    exit 1
  fi

  # --from overrides the marker for bootstrap
  if [[ -n "$from_profile" ]]; then
    echo "$from_profile" > "$swap_marker"
    echo -e "${DIM}Set current profile to ${from_profile}${RESET}"
  fi

  # Save current .claude credentials back to the profile we're leaving
  if [[ -f "$CLAUDE_HOME/.credentials.json" ]]; then
    if [[ -f "$swap_marker" ]]; then
      local prev
      prev=$(cat "$swap_marker")
      local prev_dir="$HOME/.claude-$prev"
      if [[ -d "$prev_dir" ]]; then
        cp "$CLAUDE_HOME/.credentials.json" "$prev_dir/.credentials.json"
        echo -e "${DIM}Saved credentials back to ${prev}${RESET}"
      fi
    else
      if [[ "$force" == true ]]; then
        echo -e "${DIM}No marker — skipping save-back (--force)${RESET}"
      else
        echo -e "${RED}Warning:${RESET} No active profile marker found."
        echo -e "Cannot save current credentials back. Which profile are you on now?"
        echo -e "  ${BOLD}cc-switch swap --from <current> $name${RESET}  (saves current creds to <current> first)"
        echo -e "  ${BOLD}cc-switch swap --force $name${RESET}            (skip saving, just overwrite)"
        exit 1
      fi
    fi
  fi

  cp "$profile_creds" "$CLAUDE_HOME/.credentials.json"
  echo "$name" > "$swap_marker"
  echo -e "${GREEN}Swapped.${RESET} ${BOLD}claude${RESET} now uses ${BOLD}$name${RESET} credentials."
}

cmd_list() {
  local profiles
  profiles=$(get_profiles)

  if [[ -z "$profiles" ]]; then
    echo -e "${DIM}No profiles configured. Run: cc-switch add <name>${RESET}"
    return
  fi

  echo -e "${BOLD}Configured accounts:${RESET}"
  echo ""
  while IFS= read -r name; do
    local creds="$HOME/.claude-$name/.credentials.json"
    if [[ -f "$creds" ]]; then
      echo -e "  ${BOLD}$name${RESET}  ${GREEN}logged in${RESET}"
    else
      echo -e "  ${BOLD}$name${RESET}  ${DIM}not yet logged in${RESET}"
    fi
  done <<< "$profiles"
  echo ""
}

cmd_sync() {
  check_claude
  local profiles
  profiles=$(get_profiles)

  if [[ -z "$profiles" ]]; then
    echo -e "${DIM}No profiles to sync.${RESET}"
    return
  fi

  while IFS= read -r name; do
    link_profile "$HOME/.claude-$name"
  done <<< "$profiles"
  echo -e "${GREEN}Symlinks synced.${RESET}"
}

cmd_uninstall() {
  echo -e "${BOLD}Removing cc-auth-switcher...${RESET}"

  local profiles
  profiles=$(get_profiles)

  if [[ -n "$profiles" ]]; then
    while IFS= read -r name; do
      local dir="$HOME/.claude-$name"
      if [[ -d "$dir" ]]; then
        rm -rf "$dir"
        echo -e "  ${RED}-${RESET} $dir"
      fi
    done <<< "$profiles"
  fi

  if [[ -f "$SHELL_RC" ]]; then
    sed -i '' '/# cc-switch: /d' "$SHELL_RC"
    echo -e "  ${RED}-${RESET} Removed aliases from $(basename "$SHELL_RC")"
  fi

  echo ""
  echo -e "${GREEN}Done.${RESET} Run: source $SHELL_RC"
}

# --- Token warming ---

WARM_LOG_FILE="${HOME}/.cc-switch/warm.log"
WARM_PLIST_NAME="com.cc-switch.warm"
WARM_PLIST_DST="${HOME}/Library/LaunchAgents/${WARM_PLIST_NAME}.plist"

_warm_log() {
  local ts
  ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
  mkdir -p "$(dirname "$WARM_LOG_FILE")"
  echo "${ts} $1" >> "$WARM_LOG_FILE"
}

_run_with_timeout() {
  local secs="$1"; shift
  "$@" &
  local pid=$!
  ( sleep "$secs"; kill "$pid" 2>/dev/null ) &
  local watcher=$!
  wait "$pid" 2>/dev/null
  local rc=$?
  kill "$watcher" 2>/dev/null
  wait "$watcher" 2>/dev/null
  return $rc
}

_find_claude() {
  local candidate
  for candidate in \
      "${HOME}/.local/bin/claude" \
      "/usr/local/bin/claude" \
      "/opt/homebrew/bin/claude"; do
    if [[ -x "$candidate" ]]; then
      echo "$candidate"
      return 0
    fi
  done
  return 1
}

# Check if a profile's token expires within the next 60 minutes
_token_needs_warm() {
  local creds_file="$1"
  local expires_at
  # Extract expiresAt from JSON without jq — works because it's always a number
  expires_at=$(grep -o '"expiresAt":[0-9]*' "$creds_file" 2>/dev/null | head -1 | grep -o '[0-9]*')
  if [[ -z "$expires_at" ]]; then
    return 0  # can't tell, warm it
  fi
  local now_ms=$(( $(date +%s) * 1000 ))
  local threshold_ms=$(( 60 * 60 * 1000 ))  # 60 minutes
  (( expires_at - now_ms < threshold_ms ))
}

cmd_warm() {
  local profiles
  profiles=$(get_profiles)

  if [[ -z "$profiles" ]]; then
    echo -e "${DIM}No profiles to warm.${RESET}"
    return
  fi

  local swap_marker="$CLAUDE_HOME/.cc-swap-active"
  local active=""
  if [[ -f "$swap_marker" ]]; then
    active=$(cat "$swap_marker" | tr -d '[:space:]')
  fi

  # Sync .claude credentials back to active profile
  if [[ -n "$active" && -f "$CLAUDE_HOME/.credentials.json" ]]; then
    local active_dir="$HOME/.claude-$active"
    if [[ -d "$active_dir" ]]; then
      cp "$CLAUDE_HOME/.credentials.json" "$active_dir/.credentials.json"
      _warm_log "[${active}] Synced credentials from .claude"
    fi
  fi

  local claude_bin
  claude_bin=$(_find_claude) || {
    echo -e "${RED}Error:${RESET} claude binary not found"
    _warm_log "ERROR: claude binary not found"
    return 1
  }

  local warmed=0 skipped=0 failed=0

  while IFS= read -r name; do
    local profile_dir="$HOME/.claude-$name"
    local creds="$profile_dir/.credentials.json"

    if [[ ! -f "$creds" ]]; then
      _warm_log "[${name}] No credentials — skipping"
      ((skipped++))
      continue
    fi

    if ! _token_needs_warm "$creds"; then
      _warm_log "[${name}] Token still fresh — skipping"
      ((skipped++))
      continue
    fi

    _warm_log "[${name}] Warming token..."
    if _run_with_timeout 120 env CLAUDE_CONFIG_DIR="$profile_dir" "$claude_bin" -p "hi" --max-turns 1 >/dev/null 2>&1; then
      _warm_log "[${name}] Token warmed"
      echo -e "  ${BOLD}$name${RESET}  ${GREEN}warmed${RESET}"
      ((warmed++))
    else
      _warm_log "[${name}] Warm failed"
      echo -e "  ${BOLD}$name${RESET}  ${RED}failed${RESET}"
      ((failed++))
    fi
  done <<< "$profiles"

  echo ""
  echo -e "${DIM}${warmed} warmed, ${skipped} skipped, ${failed} failed${RESET}"
  echo -e "${DIM}Log: ${WARM_LOG_FILE}${RESET}"
}

cmd_warm_setup() {
  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  cat > "$WARM_PLIST_DST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${WARM_PLIST_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>${script_path}</string>
        <string>warm</string>
    </array>
    <key>StartInterval</key>
    <integer>1800</integer>
    <key>StandardOutPath</key>
    <string>${HOME}/.cc-switch/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>${HOME}/.cc-switch/launchd-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>${HOME}/.local/bin:/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
        <key>HOME</key>
        <string>${HOME}</string>
    </dict>
</dict>
</plist>
PLIST

  mkdir -p "${HOME}/.cc-switch"
  launchctl unload "$WARM_PLIST_DST" 2>/dev/null || true
  launchctl load "$WARM_PLIST_DST"

  echo -e "${GREEN}Token warming installed.${RESET} Runs every 30 minutes."
  echo -e "  Plist: ${WARM_PLIST_DST}"
  echo -e "  Log:   ${WARM_LOG_FILE}"
  echo ""
  echo -e "To stop: ${BOLD}cc-switch warm-uninstall${RESET}"
}

cmd_warm_uninstall() {
  if [[ -f "$WARM_PLIST_DST" ]]; then
    launchctl unload "$WARM_PLIST_DST" 2>/dev/null || true
    rm -f "$WARM_PLIST_DST"
    echo -e "${GREEN}Token warming uninstalled.${RESET}"
  else
    echo -e "${DIM}Token warming not installed.${RESET}"
  fi
}

case "${1:-}" in
  add)             cmd_add "${2:-}" ;;
  remove)          cmd_remove "${2:-}" ;;
  swap)            shift; cmd_swap "$@" ;;
  list)            cmd_list ;;
  sync)            cmd_sync ;;
  warm)            cmd_warm ;;
  warm-setup)      cmd_warm_setup ;;
  warm-uninstall)  cmd_warm_uninstall ;;
  uninstall)       cmd_uninstall ;;
  -h|--help)       usage ;;
  *)               usage ;;
esac
